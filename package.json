{
  "name": "dunit",
  "version": "1.1.0",
  "description": "Personal offline kanban task tracker",
  "desktopName": "personal-task-tracker.desktop",
  "main": "electron/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev": "concurrently -k -n VITE,ELECTRON \"npm:dev:vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "smoke:db": "node scripts/smoke-db.js",
    "smoke:crash": "node scripts/smoke-crash.js",
    "package:linux": "npm run build && electron-builder --linux",
    "package:win": "npm run build && electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Duane Hughes",
  "license": "SEE LICENSE IN LICENSE",
  "type": "commonjs",
  "build": {
    "appId": "com.duanejevon.dunit",
    "productName": "DunIT - Personal KanBan Task App",
    "icon": "build/icon.png",
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office",
      "syncDesktopName": true
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^12.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "playwright-core": "^1.61.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}
